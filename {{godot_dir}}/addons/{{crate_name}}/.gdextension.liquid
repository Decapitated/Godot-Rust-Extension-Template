[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.6
reloadable = true

[libraries]
linux.debug.x86_64 =     "res://addons/{{crate_name}}/target/debug/lib{{crate_name}}.so"
linux.release.x86_64 =   "res://addons/{{crate_name}}/target/release/lib{{crate_name}}.so"
windows.debug.x86_64 =   "res://addons/{{crate_name}}/target/debug/{{crate_name}}.dll"
windows.release.x86_64 = "res://addons/{{crate_name}}/target/release/{{crate_name}}.dll"
macos.debug =            "res://addons/{{crate_name}}/target/debug/lib{{crate_name}}.dylib"
macos.release =          "res://addons/{{crate_name}}/target/release/lib{{crate_name}}.dylib"
macos.debug.arm64 =      "res://addons/{{crate_name}}/target/debug/lib{{crate_name}}.dylib"
macos.release.arm64 =    "res://addons/{{crate_name}}/target/release/lib{{crate_name}}.dylib"
